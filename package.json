{
  "name": "taskira",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "preview": "npm run preview -w apps/web",
    "tauri": "npm run tauri -w apps/tauri",
    "tauri:dev": "npm run dev -w apps/tauri",
    "tauri:build": "npm run build -w apps/tauri",
    "cap:sync": "npm run build -w apps/web && npm run sync -w apps/ios",
    "storybook": "npm run storybook -w packages/ui",
    "deploy": "node scripts/deploy.js",
    "scaffold": "node scripts/scaffold.js"
  }
}
